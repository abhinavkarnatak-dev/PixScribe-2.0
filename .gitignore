# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
next-env.d.ts

# production
/build

# ---------------------------------------------------------------------------
# Secrets - anything below here would leak credentials if committed
# ---------------------------------------------------------------------------

# Every env variant. `.env.example` is deliberately un-ignored below because it
# holds placeholders only and documents what the app needs to run.
.env
.env.*
!.env.example

# Keys, certs, and service credentials
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
*.keystore
credentials.json
service-account*.json
gha-creds-*.json
secrets.json
*.secrets

# Anything explicitly marked local
*.local

# ---------------------------------------------------------------------------
# AI assistant / editor config - may contain prompts, context, or credentials
# ---------------------------------------------------------------------------

.claude/
CLAUDE.md
AGENTS.md
.cursor/
.cursorrules
.cursorignore
.windsurfrules
.aider*
.continue/
.github/copilot-instructions.md
.mcp.json
.roo/
.clinerules

# Editors
.idea/
.vscode/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Tooling / OS noise
# ---------------------------------------------------------------------------

# vercel
.vercel

# typescript
*.tsbuildinfo

# build tool caches
.turbo
.swc/
.eslintcache

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs
*.log

# OS
.DS_Store
Thumbs.db
desktop.ini
