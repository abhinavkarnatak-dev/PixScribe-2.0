# ---------------------------------------------------------------------------
# PixScribe 2.0 - environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# App -----------------------------------------------------------------------
# Public origin of the deployment. Used for absolute URLs and Razorpay callbacks.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database ------------------------------------------------------------------
# MongoDB connection string (Atlas or self-hosted). Server-side only.
MONGODB_URI="mongodb+srv://user:password@cluster.mongodb.net/pixscribe?retryWrites=true&w=majority"

# Auth ----------------------------------------------------------------------
# Secret used to sign session JWTs. Must be at least 32 characters.
# Generate one with: openssl rand -base64 48
JWT_SECRET="replace-with-a-long-random-string-at-least-32-chars"

# ClipDrop ------------------------------------------------------------------
# Six keys used in round-robin rotation so no single key's quota is drained.
# Any key may be left blank - the rotator simply skips missing entries.
CLIPDROP_API_KEY_1=""
CLIPDROP_API_KEY_2=""
CLIPDROP_API_KEY_3=""
CLIPDROP_API_KEY_4=""
CLIPDROP_API_KEY_5=""
CLIPDROP_API_KEY_6=""

# Cloudinary ----------------------------------------------------------------
# Generated images are uploaded here; only the resulting URL is stored in Mongo.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Razorpay ------------------------------------------------------------------
# Key ID is safe to expose to the browser (Checkout needs it). The secret and
# the webhook secret are server-side only and must never reach the client.
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxx"
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET=""
# OPTIONAL. Payments work fully without this.
#
# Payment security does not depend on it: every purchase is verified by HMAC
# signature against RAZORPAY_KEY_SECRET, and any payment that completes without
# reaching us (closed tab, lost connection) is recovered by server-side
# reconciliation against the Razorpay API on the next page load.
#
# Setting it just adds a real-time confirmation path. To enable: Razorpay
# Dashboard > Settings > Webhooks > Add New Webhook, point it at
# <your-domain>/api/payments/webhook, subscribe to `payment.captured` and
# `payment.failed`, then paste the secret you chose there into this variable.
# While blank, the webhook endpoint refuses all requests.
RAZORPAY_WEBHOOK_SECRET=""
